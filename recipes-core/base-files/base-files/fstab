# Customized for Raspberry Pi 5 USB-first boot with SD fallback.

/dev/root            /               auto    defaults                            1  1
proc                 /proc           proc    defaults                            0  0
devpts               /dev/pts        devpts  mode=0620,ptmxmode=0666,gid=5       0  0
tmpfs                /run            tmpfs   mode=0755,nodev,nosuid,strictatime  0  0
tmpfs                /var/volatile   tmpfs   defaults                            0  0

# Optional boot partitions.
# nofail and a short systemd timeout prevent missing media from blocking boot.
/dev/mmcblk0p1       /boot           vfat    defaults,nofail,x-systemd.device-timeout=1s  0  0
/dev/sda1            /boot-usb       vfat    defaults,nofail,x-systemd.device-timeout=1s  0  0

